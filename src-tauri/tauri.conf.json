{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inkue",
  "version": "1.0.0",
  "identifier": "com.inkue.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Inkue",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": false
      },
      {
        "label": "preferences",
        "title": "Preferences",
        "width": 740,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "float-timer",
        "title": "Inkue Timer",
        "width": 420,
        "height": 110,
        "decorations": false,
        "visible": false,
        "resizable": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "license": "GPL-3.0-or-later",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libmpv2 | libmpv1", "libxkbcommon-x11-0"]
      }
    }
  }
}
